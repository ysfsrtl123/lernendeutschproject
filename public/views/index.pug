    script.
      const words = ["der", "die", "das", "und", "sein", "haben", "ich", "du", "er", "sie", "es", "wir", "ihr", "sie", "Sie", "ein", "eine", "nicht", "ja", "nein", "bitte", "danke", "gut", "schlecht", "groß", "klein", "alt", "jung", "neu", "schön", "hässlich", "teuer", "billig", "schnell", "langsam", "heiß", "kalt", "warm", "kühl", "essen", "trinken", "gehen", "kommen", "sehen", "hören", "sprechen", "schreiben", "lesen", "lernen", "spielen", "kaufen", "verkaufen", "arbeiten", "wohnen", "schlafen", "aufstehen", "sitzen", "stehen", "liegen", "fragen", "antworten", "öffnen", "schließen", "machen", "tun", "geben", "nehmen", "bringen", "zeigen", "erklären", "finden", "suchen", "verlieren", "gewinnen", "lieben", "mögen", "hassen", "wissen", "kennen", "verstehen", "brauchen", "wollen", "müssen", "können", "dürfen", "sollen", "anfangen", "aufhören", "beginnen", "beenden", "bleiben", "fahren", "fliegen", "laufen", "schwimmen", "springen"];

      function click() {
          var y = Math.floor(Math.random() * words.length);
          const z = words[y];
          document.getElementById('change').textContent = "Kelimenin Anlamı Nedir?";
          document.getElementById('question').textContent = z;
      }

      document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('spinner-container').style.display = 'none';
      });
