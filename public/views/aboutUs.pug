doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet", integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH", crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js", integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz", crossorigin="anonymous")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    title Learn Deutsch | Home Page
    style.
      body {
          display: flex;
          flex-direction: column;
          min-height: 100vh;
      }
      main {
          flex: 1;
      }
      footer {
          background-color: #ffc107;
          color: white;
      }
      a {
          text-decoration: none;
      }
      .spinner-container {
          display: flex;
          justify-content: center;
          align-items: center;
          height: 100vh;
          background-color: rgba(255, 255, 255, 0.8);
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          z-index: 9999;
      }

  body(style="background-color: red;")
    //- Spinner
    #spinner-container.spinner-container
      .spinner-border(role="status")
        span.visually-hidden Loading...
    //- Navbar
    .container-fluid.bg-dark.p-3
      nav.navbar.navbar-expand-lg.navbar-dark
        .container-fluid
          a.navbar-brand(href="#") b i DEUTSCH
          button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav", aria-controls="navbarNav", aria-expanded="false", aria-label="Toggle navigation")
            span.navbar-toggler-icon
          .collapse.navbar-collapse#navbarNav
            ul.navbar-nav.ms-auto
              li.nav-item
                a.nav-link(aria-current="page", href="#") i.bi.bi-house-door-fill Startseite
              li.nav-item
                a.nav-link.active(href="#") Über uns
              li.nav-item
                a.nav-link(href="#") i.bi.bi-journal-check Übungen

